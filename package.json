{
  "name": "fluxer-bot-template",
  "version": "1.0.0",
  "description": "A starter template for building bots with @fluxerjs/core — includes a custom command handler, event handler, and project structure.",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "build:clean": "rimraf build/ && npm run build",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/"
  },
  "keywords": [
    "fluxer",
    "bot",
    "template",
    "fluxerjs"
  ],
  "author": "dogbonewish",
  "license": "MIT",
  "dependencies": {
    "@fluxerjs/core": "^1.2.4",
    "dotenv": "^17.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
